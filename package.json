{
  "name": "@jurgen1c/agent-memory-cli",
  "version": "0.2.0",
  "description": "Repository-local agent memory CLI based on atomic claims and generated indexes.",
  "license": "MIT",
  "main": "dist/agent-memory.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/jurgen1c/agent_memory"
  },
  "keywords": [
    "agent",
    "memory",
    "cli",
    "codex",
    "repository"
  ],
  "type": "module",
  "bin": {
    "agent-memory": "dist/agent-memory.js"
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.5.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.6"
  },
  "files": [
    "dist/",
    "packages/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:web && bun build packages/cli/src/index.ts --target=node --outfile=dist/agent-memory.js",
    "build:web": "bun run --cwd packages/web build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p packages/web/tsconfig.json",
    "audit": "bun audit --audit-level moderate",
    "ci": "bun run version:check && bun run audit && bun run lint && bun run typecheck && bun test && bun run build",
    "lint": "eslint .",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "version": "node scripts/sync-workspace-versions.mjs --stage",
    "version:check": "node scripts/sync-workspace-versions.mjs --check",
    "dev": "bun packages/cli/src/index.ts",
    "ui:mock": "scripts/run-mock-ui.sh",
    "prepack": "bun run build"
  },
  "engines": {
    "node": ">=25"
  }
}
