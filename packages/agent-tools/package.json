{
  "name": "@jurgen1c/agent-tools",
  "version": "0.2.0",
  "description": "Lightweight meta package for discovering Agent Memory and Agentflow CLI packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jurgen1c/agent_memory",
    "directory": "packages/agent-tools"
  },
  "keywords": [
    "agent",
    "agent-memory",
    "agentflow",
    "cli",
    "tools"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js",
    "prepack": "bun run build"
  }
}
