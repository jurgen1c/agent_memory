{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Memory Claim",
  "type": "object",
  "required": ["id", "type", "system", "status", "confidence", "severity", "title", "claim", "source_files", "tags"],
  "properties": {
    "id": { "type": "string" },
    "type": { "enum": ["fact", "rule", "constraint", "workflow", "recipe", "risk", "decision", "deprecation"] },
    "system": { "type": "string" },
    "status": { "enum": ["current", "proposed", "stale", "deprecated", "experimental", "needs_verification", "needs_review", "rejected"] },
    "confidence": { "enum": ["low", "medium", "high", "verified"] },
    "severity": { "enum": ["info", "normal", "important", "critical"] },
    "title": { "type": "string" },
    "claim": { "type": "string" },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "related_files": { "type": "array", "items": { "type": "string" } },
    "symbols": { "type": "array", "items": { "type": "string" } },
    "routes": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "array", "items": { "type": "string" } }
  }
}
