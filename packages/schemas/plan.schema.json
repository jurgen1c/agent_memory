{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Memory Plan Template",
  "type": "object",
  "required": ["id", "title", "system", "status", "stages"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "system": { "type": "string" },
    "status": { "enum": ["current", "proposed", "needs_review", "deprecated", "stale", "rejected"] },
    "intent_triggers": { "type": "array", "items": { "type": "string" } },
    "recipes": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "goal"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "goal": { "type": "string" },
          "claim_refs": { "type": "array", "items": { "type": "string" } },
          "recipe_refs": { "type": "array", "items": { "type": "string" } },
          "profile_traits": { "type": "array", "items": { "type": "string" } },
          "source_files": { "type": "array", "items": { "type": "string" } },
          "verification": { "type": "array", "items": { "type": "string" } },
          "done_when": { "type": "array", "items": { "type": "string" } },
          "memory_updates": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
