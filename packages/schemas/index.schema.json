{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Memory Index",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "summary": { "type": "string" },
    "claim_globs": { "type": "array", "items": { "type": "string" } },
    "recipe_globs": { "type": "array", "items": { "type": "string" } },
    "default_queries": { "type": "array", "items": { "type": "string" } },
    "watched_files": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
