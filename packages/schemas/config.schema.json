{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Memory Config",
  "type": "object",
  "required": ["version", "memory_root", "database_path", "claims", "graphs", "indexes", "recipes", "waivers"],
  "properties": {
    "version": { "const": 1 },
    "memory_root": { "type": "string" },
    "database_path": { "type": "string" },
    "claims": { "type": "array", "items": { "type": "string" } },
    "graphs": { "type": "array", "items": { "type": "string" } },
    "indexes": { "type": "array", "items": { "type": "string" } },
    "recipes": { "type": "array", "items": { "type": "string" } },
    "plans": { "type": "array", "items": { "type": "string" } },
    "profiles": { "type": "array", "items": { "type": "string" } },
    "waivers": { "type": "array", "items": { "type": "string" } }
  }
}
